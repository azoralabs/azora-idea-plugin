<idea-plugin>
    <id>com.azora.lang.idea</id>
    <name>Azora Language</name>
    <version>0.0.3</version>
    <vendor email="support@azora.dev" url="https://azora.dev">AzoraTech</vendor>
    <description><![CDATA[
        Full language support for the <b>Azora</b> programming language.

        <ul>
            <li>Syntax highlighting with semantic keyword coloring (declaration, control-flow, modifier, memory, reactive)</li>
            <li>Context-aware code completion for types, functions, variables, pack fields, enum variants, zone members, std modules, and annotations</li>
            <li>Go-to-definition (Ctrl+Click) for identifiers across files and stdlib</li>
            <li>Quick documentation (Ctrl+Q) showing type signatures, parameters, and fields</li>
            <li>Error and warning annotations from preprocessor, parser, and semantic analysis</li>
            <li>Brace matching and code folding (declarations, comments, imports, and editor regions)</li>
            <li>Structure view (outline of functions, packs, enums, views, impls, tests, etc.)</li>
            <li>Find usages for identifiers</li>
            <li>Line and block commenting</li>
            <li>File templates for new .az files</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Language -->
        <fileType
            name="Azora"
            implementationClass="com.azora.lang.idea.AzoraFileType"
            fieldName="INSTANCE"
            language="Azora"
            extensions="az"/>

        <lang.parserDefinition
            language="Azora"
            implementationClass="com.azora.lang.idea.AzoraParserDefinition"/>

        <!-- Syntax Highlighting -->
        <lang.syntaxHighlighterFactory
            language="Azora"
            implementationClass="com.azora.lang.idea.highlighting.AzoraSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="com.azora.lang.idea.highlighting.AzoraColorSettingsPage"/>

        <langCodeStyleSettingsProvider
            implementation="com.azora.lang.idea.formatting.AzoraCodeStyleSettingsProvider"/>

        <!-- Code Completion -->
        <completion.contributor
            language="Azora"
            implementationClass="com.azora.lang.idea.completion.AzoraCompletionContributor"/>

        <!-- Go to Declaration -->
        <gotoDeclarationHandler
            implementation="com.azora.lang.idea.navigation.AzoraGoToDeclarationHandler"/>

        <!-- Documentation -->
        <lang.documentationProvider
            language="Azora"
            implementationClass="com.azora.lang.idea.documentation.AzoraDocumentationProvider"/>

        <!-- Annotations (errors/warnings) -->
        <externalAnnotator
            language="Azora"
            implementationClass="com.azora.lang.idea.annotator.AzoraExternalAnnotator"/>

        <!-- Brace Matching -->
        <lang.braceMatcher
            language="Azora"
            implementationClass="com.azora.lang.idea.AzoraBraceMatcher"/>

        <!-- Commenter -->
        <lang.commenter
            language="Azora"
            implementationClass="com.azora.lang.idea.AzoraCommenter"/>

        <!-- Code Folding -->
        <lang.foldingBuilder
            language="Azora"
            implementationClass="com.azora.lang.idea.folding.AzoraFoldingBuilder"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory
            language="Azora"
            implementationClass="com.azora.lang.idea.structure.AzoraStructureViewFactory"/>

        <!-- Find Usages -->
        <lang.findUsagesProvider
            language="Azora"
            implementationClass="com.azora.lang.idea.findusages.AzoraFindUsagesProvider"/>

        <!-- Symbol Service (project-level) -->
        <projectService
            serviceImplementation="com.azora.lang.idea.symbol.AzoraSymbolService"/>

        <!-- New Project Wizard -->
        <newProjectWizard.generator
            implementation="com.azora.lang.idea.project.AzoraNewProjectWizard"/>

        <!-- Build System -->
        <projectService
            serviceImplementation="com.azora.lang.idea.build.AzoraProjectConfigService"/>

        <postStartupActivity
            implementation="com.azora.lang.idea.build.AzoraProjectStartupActivity"/>

        <editorNotificationProvider
            implementation="com.azora.lang.idea.build.AzoraTomlSyncNotification"/>

        <!-- Run Configuration -->
        <configurationType
            implementation="com.azora.lang.idea.run.AzoraConfigurationType"/>

        <runConfigurationProducer
            implementation="com.azora.lang.idea.run.AzoraRunInterpretProducer"/>

        <runConfigurationProducer
            implementation="com.azora.lang.idea.run.AzoraRunNativeProducer"/>

        <runLineMarkerContributor
            language="Azora"
            implementationClass="com.azora.lang.idea.run.AzoraRunLineMarkerContributor"/>
    </extensions>

    <actions>
        <!-- New Azora Project action: File > New and Welcome Screen -->
        <action
            id="Azora.NewProject"
            class="com.azora.lang.idea.project.AzoraNewProjectAction"
            text="Azora Project"
            description="Create a new Azora project"
            icon="/icons/azora_icon.png">
            <add-to-group group-id="NewGroup" anchor="first"/>
            <add-to-group group-id="WelcomeScreen.QuickStart" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
